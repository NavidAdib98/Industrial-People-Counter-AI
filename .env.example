# ============================================
# LOGGING SETTINGS
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Most detailed (all logs)
# - INFO: General information (recommended)
# - WARNING: Only warnings and errors
# - ERROR: Only errors
# - CRITICAL: Only critical errors
LOG_LEVEL=INFO

# ============================================
# VIDEO SETTINGS
# ============================================
# Path to video file or use 0 for webcam
VIDEO_PATH=videos/test_video.mp4

# Video Resize (for faster processing)
# Set to true to resize video before processing
RESIZE_VIDEO=false
RESIZE_WIDTH=640
RESIZE_HEIGHT=480

# ============================================
# MODEL SETTINGS
# ============================================
# Model file path (supports .pt, .onnx, and OpenVINO folders)
# Options: yolo11n.pt, yolo11n.onnx, yolo11n_openvino_model, etc.
MODEL_PATH=models/yolo11n.pt

# ============================================
# DETECTION SETTINGS
# ============================================
# Confidence threshold for detections (0.1 - 1.0)
CONF_THRESHOLD=0.4

# NMS IoU threshold (0.1 - 1.0, lower = fewer overlapping boxes)
IOU_THRESHOLD=0.5

# Maximum detections per frame
MAX_DETECTIONS=300

# Use FP16 half precision (true/false, faster on GPU)
HALF_PRECISION=false

# Device: cpu, cuda, or mps
DEVICE=cpu

# ============================================
# TRACKER SETTINGS
# ============================================
# Supervision ByteTrack parameters:
# Confidence threshold to activate a new track (0.0-1.0)
TRACK_ACTIVATION_THRESHOLD=0.25

# IoU threshold for matching detections to tracks (0.0-1.0)
MINIMUM_MATCHING_THRESHOLD=0.8

# Frames to keep a lost track alive before removing it
LOST_TRACK_BUFFER=30

# Minimum consecutive frames to confirm a track
MINIMUM_CONSECUTIVE_FRAMES=1

# Video frame rate (for speed estimation)
FRAME_RATE=30

# ============================================
# POLYGON ROI SETTINGS
# ============================================
# Path to GeoJSON file containing polygon definition
# Format: GeoJSON FeatureCollection with Polygon geometry
# Coordinates are normalized (0.0 to 1.0) relative to frame size
POLYGON_FILE=polygons/zone1.geojson

# Color settings (fallback if not defined in GeoJSON)
# Colors are in RGB format (Red, Green, Blue)
COLOR_INSIDE=(0,255,0)    # Green - people inside the polygon
COLOR_OUTSIDE=(255,0,0)   # Red - people outside the polygon

# Polygon transparency (0.0 = invisible, 1.0 = solid)
POLYGON_ALPHA=0.2

# ============================================
# OUTPUT SETTINGS
# ============================================
# Save the annotated output video
SAVE_OUTPUT=true

# Show live preview window during processing
SHOW_PREVIEW=true

# ============================================
# EXAMPLE POLYGON CONFIGURATIONS
# ============================================
# Uncomment one of these to use a different polygon:

# Rectangle in center
# POLYGON_FILE=polygons/rectangle.geojson

# Entrance zone (bottom area)
# POLYGON_FILE=polygons/entrance.geojson

# Custom zone from polygon selector tool
# POLYGON_FILE=polygons/my_zone.geojson