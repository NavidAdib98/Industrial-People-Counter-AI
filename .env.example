# ============================================
# VIDEO
# ============================================
# Path to your video file or use 0 for webcam
VIDEO_PATH=videos/test_video.mp4

# ============================================
# MODEL
# ============================================
# Model file: yolo11n.pt (smallest), yolo11s.pt, yolo11m.pt, etc.
MODEL_NAME=yolo11n.pt

# Confidence threshold (0.3-0.7 recommended)
CONF_THRESHOLD=0.4

# Device: cpu or cuda
DEVICE=cpu

# ============================================
# TRACKER
# ============================================
# Options: bytetrack.yaml, botsort.yaml, fasttrack.yaml, tracktrack.yaml
TRACKER_TYPE=bytetrack.yaml

# ============================================
# OUTPUT
# ============================================
# Save output video
SAVE_OUTPUT=true

# Show preview window
SHOW_PREVIEW=true