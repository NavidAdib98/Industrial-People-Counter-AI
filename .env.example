# ============================================
# VIDEO SETTINGS
# ============================================
# Path to video file or use 0 for webcam
VIDEO_PATH=videos/test_video.mp4

# ============================================
# MODEL SETTINGS
# ============================================
# Model file path (supports .pt, .onnx, and OpenVINO folders)
# Options: yolo11n.pt, yolo11n.onnx, yolo11n_openvino_model, etc.
MODEL_PATH=models/yolo11n.pt

# Confidence threshold for detections (0.3 - 0.7 recommended)
CONF_THRESHOLD=0.4

# Device: cpu or cuda (for GPU)
DEVICE=cpu

# ============================================
# TRACKER SETTINGS
# ============================================
# Tracker type:
# - bytetrack.yaml: Lightweight, good for static cameras
# - botsort.yaml: Better for moving cameras
# - fasttrack.yaml: Optimized for occlusion handling
# - tracktrack.yaml: Best for crowded scenes
TRACKER_TYPE=bytetrack.yaml

# ============================================
# POLYGON ROI SETTINGS
# ============================================
# Path to GeoJSON file containing polygon definition
# Format: GeoJSON FeatureCollection with Polygon geometry
# Coordinates are normalized (0.0 to 1.0) relative to frame size
POLYGON_FILE=polygons/default_polygon.geojson

# Color settings (fallback if not defined in GeoJSON)
# Colors are in RGB format (Red, Green, Blue)
COLOR_INSIDE=(0,255,0)    # Green - people inside the polygon
COLOR_OUTSIDE=(255,0,0)   # Red - people outside the polygon

# Polygon transparency (0.0 = invisible, 1.0 = solid)
POLYGON_ALPHA=0.3

# ============================================
# OUTPUT SETTINGS
# ============================================
# Save the annotated output video
SAVE_OUTPUT=true

# Show live preview window during processing
SHOW_PREVIEW=true

# ============================================
# EXAMPLE POLYGON CONFIGURATIONS
# ============================================
# Uncomment one of these to use a different polygon:

# Rectangle in center
# POLYGON_FILE=polygons/rectangle.geojson

# Entrance zone (bottom area)
# POLYGON_FILE=polygons/entrance.geojson

# Custom zone from polygon selector tool
# POLYGON_FILE=polygons/my_zone.geojson